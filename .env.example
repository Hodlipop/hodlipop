# Hodlipop environment variables

# --- Web (copy apps/web/.env.example → apps/web/.env.local) ---
NEXT_PUBLIC_SITE_URL=https://hodlipop.com
NEXT_PUBLIC_API_URL=https://api.hodlipop.com

# Matomo analytics (optional — tracking disabled if unset)
# Set only these two; MATOMO_PROXY_TARGET is derived automatically from MATOMO_URL.
# Required at BUILD time (pnpm build:opennext) and at CDK deploy (pnpm deploy:aws).
# MATOMO_URL=https://matomo.example.com
# NEXT_PUBLIC_MATOMO_SITE_ID=1

# Tech stack logo style: "color" or "mono"
# NEXT_PUBLIC_TECH_LOGO_VARIANT=color

# --- AWS deploy (shell env for pnpm deploy:aws / CDK) ---
# AWS_REGION=eu-west-3
# MATOMO_URL=https://matomo.example.com
# NEXT_PUBLIC_MATOMO_SITE_ID=1
# CLOUDFRONT_CERTIFICATE_ARN=arn:aws:acm:us-east-1:ACCOUNT:certificate/UUID
