# Copy to apps/web/.env.local

# Site URL (SEO canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API URL (optional — falls back to local JSON seed data)
# NEXT_PUBLIC_API_URL=

# Matomo analytics (optional — disabled if unset)
# Set only MATOMO_URL + NEXT_PUBLIC_MATOMO_SITE_ID (no MATOMO_PROXY_TARGET needed).
# MATOMO_URL must be present before `pnpm build:opennext` — the proxy path is baked into the build.
# MATOMO_URL=https://matomo.example.com
# NEXT_PUBLIC_MATOMO_SITE_ID=1

# Tech stack logo style: "color" or "mono"
# NEXT_PUBLIC_TECH_LOGO_VARIANT=color
